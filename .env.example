# Asana Personal Access Token — create at https://app.asana.com/0/my-apps
ASANA_PERSONAL_ACCESS_TOKEN=your_token_here

# Your Asana workspace gid. Find it by running the `get_me` tool (it lists your
# workspaces with gids), or take it from any Asana URL: app.asana.com/0/<WORKSPACE_GID>/...
ASANA_WORKSPACE_GID=your_workspace_gid_here

# Optional: enable request logging to stderr
# DEBUG=asana-mcp
